# Required for Grok image analysis and OCR
XAI_API_KEY="your_api_key_goes_here"
XAI_MODEL=grok-4.20-reasoning

# WhatsApp sending mode:
# demo   -> just logs success locally
# twilio -> sends real WhatsApp if Twilio credentials are configured
WHATSAPP_MODE=demo

# Twilio WhatsApp configuration (only needed if WHATSAPP_MODE=twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
TWILIO_WHATSAPP_TO=whatsapp:+919067443576

# Optional Tesseract path on Windows if pytesseract is installed
# TESSERACT_CMD=C:\\Program Files\\Tesseract-OCR\\tesseract.exe
